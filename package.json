{
  "name": "arcade-platform",
  "version": "1.0.0",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "pnpm --filter electron dev",
    "build:games": "pnpm --filter \"game-*\" build",
    "build:electron": "pnpm --filter electron build",
    "build": "pnpm build:games && pnpm build:electron",
    "preview:electron": "pnpm --filter electron preview",
    "dev:game": "pnpm --filter game-gold-miner dev",
    "dev:flappy": "pnpm --filter game-flappy dev"
  }
}
