# Run package.json scripts through Git Bash so POSIX shell scripts
# (e.g. "game:new": "sh new-game.sh") work from PowerShell/cmd too.
# NOTE: this is a Windows-specific absolute path. On Linux/macOS, comment
# this out (scripts run under the default shell there with no issue).
script-shell=C:\Program Files\Git\bin\bash.exe
